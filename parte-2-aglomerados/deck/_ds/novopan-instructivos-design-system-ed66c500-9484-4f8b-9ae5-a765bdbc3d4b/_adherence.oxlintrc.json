{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/checklists/**",
              "components/feedback/**",
              "components/process/**",
              "components/structure/**",
              "components/tables/**",
              "ui_kits/guia_de_campo/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Barlow|Barlow Semi Condensed|Material Symbols Rounded))/i]",
        "message": "Font not provided by the design system. Available: Barlow, Barlow Semi Condensed, Material Symbols Rounded."
      },
      {
        "selector": "JSXOpeningElement[name.name='ActivityStep'] > JSXAttribute > JSXIdentifier[name!=/^(?:number|title|children|icon|role|systemKey|done|style|key|ref|className|style|children)$/]",
        "message": "<ActivityStep> doesn't accept that prop. Declared props: number, title, children, icon, role, systemKey, done, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|icon|solid|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, icon, solid, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:brand|accent|neutral|warn|danger|ok|info)$/]",
        "message": "<Badge> tone must be one of 'brand' | 'accent' | 'neutral' | 'warn' | 'danger' | 'ok' | 'info'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Callout'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|title|label|children|icon|style|key|ref|className|style|children)$/]",
        "message": "<Callout> doesn't accept that prop. Declared props: variant, title, label, children, icon, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Callout'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:advertencia|prohibido|correcto|nota|excepcion)$/]",
        "message": "<Callout> variant must be one of 'advertencia' | 'prohibido' | 'correcto' | 'nota' | 'excepcion'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChecklistItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:text|hint|checked|key|ref|className|style|children)$/]",
        "message": "<ChecklistItem> doesn't accept that prop. Declared props: text, hint, checked."
      },
      {
        "selector": "JSXOpeningElement[name.name='FlowStep'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|icon|caption|key|ref|className|style|children)$/]",
        "message": "<FlowStep> doesn't accept that prop. Declared props: label, icon, caption."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|color|fill|weight|style|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, color, fill, weight, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='InfoTableColumn'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|align|width|key|ref|className|style|children)$/]",
        "message": "<InfoTableColumn> doesn't accept that prop. Declared props: label, align, width."
      },
      {
        "selector": "JSXOpeningElement[name.name='InfoTableColumn'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center|right)$/]",
        "message": "<InfoTableColumn> align must be one of 'left' | 'center' | 'right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='KeyCap'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|label|size|style|key|ref|className|style|children)$/]",
        "message": "<KeyCap> doesn't accept that prop. Declared props: children, label, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='KeyCap'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<KeyCap> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProcessCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:code|title|icon|tone|responsible|frequency|children|footer|style|key|ref|className|style|children)$/]",
        "message": "<ProcessCard> doesn't accept that prop. Declared props: code, title, icon, tone, responsible, frequency, children, footer, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProcessCard'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:brand|accent)$/]",
        "message": "<ProcessCard> tone must be one of 'brand' | 'accent'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:number|title|icon|eyebrow|style|key|ref|className|style|children)$/]",
        "message": "<SectionHeader> doesn't accept that prop. Declared props: number, title, icon, eyebrow, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
